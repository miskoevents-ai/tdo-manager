{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "devCommand": "next dev",
  "crons": [
    { "path": "/api/cron/diario", "schedule": "0 6 * * *" },
    { "path": "/api/cron/digest", "schedule": "0 11 * * 5" }
  ]
}
